PORT=8787
API_PUBLIC_URL=http://127.0.0.1:8787
WEB_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8787
NEXT_PUBLIC_OVERLAY_URL=https://omnichat.wtf/overlay

DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
SESSION_SECRET=generate-a-long-random-string
TOKEN_ENCRYPTION_KEY=64_hex_chars_32_bytes_e.g_openssl_rand_hex_32
JWT_SECRET=legacy-fallback-for-session

SUPER_ADMIN_EMAILS=you@example.com

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Must match a redirect URL in the Twitch app exactly
TWITCH_REDIRECT_URI=http://localhost:8787/auth/twitch/callback

KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
KICK_REDIRECT_URI=http://localhost:8787/auth/kick/callback

# Google — Cloud Console → OAuth 2.0 Client → redirect URI must match exactly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/auth/google/callback

# YouTube live chat — uses the same Google OAuth client as above.
# Redirect URI is auto-derived from GOOGLE_REDIRECT_URI if omitted.
# Enable YouTube Data API v3 and add this URI in Google Cloud Console:
YOUTUBE_REDIRECT_URI=http://localhost:8787/auth/youtube/callback
# Server API key (omnichat-yt-2) for videos.list only — fresh quota, decoupled from user OAuth
YOUTUBE_API_KEY=

# X (Twitter) — use OAuth 2.0 credentials, NOT the legacy API Key (~25 chars).
# developer.x.com → your app → Keys and tokens → "OAuth 2.0 Client ID and Client Secret"
# OAuth 2.0 Client ID is ~34 chars (e.g. ends with :1:ci when decoded). API Key is ~25 alphanumeric only.
# User auth: OAuth 2.0 on · Type: Web App, Automated App or Bot · Permissions: Read and write
# Callback URI here must EXACTLY match the portal (use 127.0.0.1, not localhost, for local dev)
# OAuth scopes requested: users.read tweet.read offline.access (tweet.read required for /users/me)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://127.0.0.1:8787/auth/x/callback
# Optional — app-only API access; not used for user sign-in
X_BEARER_TOKEN=

# Stripe — OM+ subscription ($4.99/mo)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
# Optional fallback Payment Link if checkout API is unavailable
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# Experimental: server-side X live chat scrape using YOUR logged-in session (Playwright).
# Export cookies from Chrome → DevTools → Application → Cookies → x.com (auth_token + ct0).
# Revoke/rotate if leaked. Sessions expire — re-export when scrape stops working.
X_SERVER_SCRAPE_ENABLED=0
X_AUTH_TOKEN=
X_CT0=
# 1 = headless (local dev). 0 = real browser — use on VPS with xvfb (see docs/VPS-DEPLOY.md)
X_SCRAPE_HEADLESS=1
# Or full cookie JSON: X_SESSION_COOKIES=[{"name":"auth_token","value":"..."},{"name":"ct0","value":"..."}]
# Auto-refresh: recycle browser after stall (ms, default 180000) or scheduled (default 30min)
X_SCRAPE_STALL_MS=180000
X_SCRAPE_RECYCLE_MS=1800000
# Auto re-login when the saved session expires (avoids manual pnpm x:login).
# Username/handle without @, and password. Email/phone helps clear identity prompts.
# X_LOGIN_TOTP_SECRET (base32) is REQUIRED if the account uses 2FA.
X_LOGIN_USERNAME=
X_LOGIN_PASSWORD=
X_LOGIN_EMAIL=
X_LOGIN_TOTP_SECRET=
