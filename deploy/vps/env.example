# Copy to repo root as .env on the VPS: cp deploy/vps/env.example .env
# Fill secrets and X cookies before starting the service.

PORT=8787
NODE_ENV=production

# Public URLs — replace with your DuckDNS or domain
API_PUBLIC_URL=https://api.yourname.duckdns.org
WEB_APP_URL=https://your-app.vercel.app

# Simplest DB on VPS (web talks to API only; data lives here)
USE_LOCAL_DB=1

SESSION_SECRET=generate-long-random-string
TOKEN_ENCRYPTION_KEY=64_hex_chars_from_openssl_rand_hex_32
JWT_SECRET=same-or-different-long-string

SUPER_ADMIN_EMAILS=you@example.com

# X live chat — server scrape (24/7, no PC extension)
X_SERVER_SCRAPE_ENABLED=1
X_SCRAPE_HEADLESS=0
X_AUTH_TOKEN=
X_CT0=
X_SCRAPE_STALL_MS=180000
X_SCRAPE_RECYCLE_MS=1800000
# Auto re-login when the saved X session expires (no more manual pnpm x:login).
# Username/handle (no @) and password. Email/phone helps pass identity prompts.
# TOTP secret (base32) is REQUIRED if the account has 2FA enabled.
X_LOGIN_USERNAME=
X_LOGIN_PASSWORD=
X_LOGIN_EMAIL=
X_LOGIN_TOTP_SECRET=

# Rumble live chat — server ingest (watch any channel by link, no API key)
RUMBLE_SERVER_INGEST_ENABLED=1
RUMBLE_OFFLINE_RETRY_MS=45000
# Set to 0 on VPS with xvfb if HTML resolution fails (Playwright fallback)
RUMBLE_SCRAPE_HEADLESS=1

# OAuth — use HTTPS callbacks on this VPS host
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=https://api.yourname.duckdns.org/auth/twitch/callback

KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
KICK_REDIRECT_URI=https://api.yourname.duckdns.org/auth/kick/callback

X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=https://api.yourname.duckdns.org/auth/x/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.yourname.duckdns.org/auth/google/callback

YOUTUBE_REDIRECT_URI=https://api.yourname.duckdns.org/auth/youtube/callback

# Optional: Supabase instead of USE_LOCAL_DB
# DATABASE_URL=postgresql://...
