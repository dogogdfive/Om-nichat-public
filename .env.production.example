# Production (Vercel) — set these in each Vercel project, not in git.
# Production domain: omnichat.wtf

# --- API project (apps/api) ---
API_PUBLIC_URL=https://api.omnichat.wtf
WEB_APP_URL=https://omnichat.wtf
PORT=8787

DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-west-1.pooler.supabase.com:6543/postgres
SESSION_SECRET=
TOKEN_ENCRYPTION_KEY=
SUPER_ADMIN_EMAILS=

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=https://api.omnichat.wtf/auth/twitch/callback

KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
KICK_REDIRECT_URI=https://api.omnichat.wtf/auth/kick/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.omnichat.wtf/auth/google/callback
YOUTUBE_REDIRECT_URI=https://api.omnichat.wtf/auth/youtube/callback
YOUTUBE_API_KEY=

# OAuth 2.0 Client ID (~34 chars) — NOT the API Key (~25 chars). See developer.x.com → Keys and tokens.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=https://api.omnichat.wtf/auth/x/callback

# --- Web project (apps/web) ---
NEXT_PUBLIC_API_URL=https://api.omnichat.wtf
NEXT_PUBLIC_X_API_URL=https://api.omnichat.wtf
